# ── Jonche Platform Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string

# API
API_HOST=localhost
API_PORT=5001
API_KEY=your-internal-api-key

# Database (SQLite for dev, Postgres for prod)
DATABASE_URL=sqlite:///jonche.db

# PythonAnywhere
PYTHONANYWHERE_USERNAME=your-username

# Apliiq (print-on-demand fulfillment)
# Find these in your Apliiq account → Stores → your custom store
APLIIQ_APP_KEY=your-apliiq-app-key
APLIIQ_SHARED_SECRET=your-apliiq-shared-secret